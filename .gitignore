/**
 * .gitignore file
 */

# Environment files
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Logs
logs/
*.log

# Uploads
uploads/

# Composer
vendor/
composer.lock

# Session files
session_files/

# Cache
cache/

# Database backups
*.sql
!database/*.sql

# Node modules (if using any frontend build tools)
node_modules/
package-lock.json
yarn.lock

# OS
Thumbs.db
.DS_Store

# Editor backups
*.bak
*.backup

# Temporary files
tmp/
temp/
*.tmp

# Configuration files with sensitive data
app/config/database.php (if using local overrides)

